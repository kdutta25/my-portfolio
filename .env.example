# Preferred: my-portfolio-api origin (or origin + path prefix before /v1), e.g. http://localhost:3001
# or https://your-api.onrender.com or https://www.example.com/api
# Do NOT set this to the portfolio site origin alone (e.g. https://www.kaustubhdutta.com) unless that host
# reverse-proxies /v1 or /api to my-portfolio-api.
# If you pasted .../v1, a trailing /v1 is stripped automatically.
VITE_CONTENT_API_BASE_URL=http://localhost:3001

# Optional: GitHub Project Pages subpath only (e.g. /my-portfolio/). Custom domain at root: omit.
# VITE_BASE_PATH=/my-portfolio/

# Legacy: full URL to GET /v1/site-content — only the origin is used if VITE_CONTENT_API_BASE_URL is unset.
# VITE_SITE_CONTENT_URL=http://localhost:3001/v1/site-content

# Production (npm run build): same host as SPA only if /v1 is reverse-proxied to my-portfolio-api:
# VITE_CONTENT_API_BASE_URL=https://www.kaustubhdutta.com
# VITE_ALLOW_SAME_ORIGIN_CONTENT_API=true

# Dev only (npm start): if shell/.env.local sets the bare portfolio URL, Vite uses that unless you unset it.
# The app then falls back to localhost:3001; override with:
# VITE_DEV_DEFAULT_CONTENT_API_BASE=http://127.0.0.1:3002
# Or keep production as API base in dev: VITE_DEV_ALLOW_BARE_PORTFOLIO_ORIGIN_API=true
